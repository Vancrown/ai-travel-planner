# Copy to .env and set at least OPENAI_API_KEY

# Required for AI itinerary generation
OPENAI_API_KEY=

# Optional: override model and endpoint (default: OpenAI)
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
# OPENAI_FALLBACK_MODEL=gpt-4o-mini

# Optional: timeouts and limits
# LLM_TIMEOUT_SECONDS=120
# LLM_MAX_RETRIES=2
# CACHE_TTL_SECONDS=300
# RATE_LIMIT_REQUESTS=20
# RATE_LIMIT_WINDOW_SECONDS=60

# Optional: app
# APP_ENV=development
# LOG_LEVEL=INFO

# ── GitHub Models (free) ─────────────────────────────────────────
# OPENAI_API_KEY=github_pat_...
# OPENAI_BASE_URL=https://models.inference.ai.azure.com
# OPENAI_MODEL=gpt-4o
